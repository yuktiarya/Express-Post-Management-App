<!DOCTYPE html>
<html lang="en">
<head>
    <title>Create Post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="navbar">Create New Post</div>

<div class="container">
    <div class="card">
        <form method="post" action="/posts">
            <input type="text" name="username" placeholder="Enter username" required>
            <textarea name="content" rows="6" placeholder="Write your post..." required></textarea>
            <button class="btn create">Create Post</button>
        </form>
    </div>
</div>

</body>
</html>